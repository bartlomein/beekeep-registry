{
  "name": "beekeep-registry",
  "version": "0.1.0",
  "private": true,
  "description": "Validation tooling for the public beekeep.sh Buzz agent registry",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build:cli": "npm run build --workspace @beekeep-sh/cli",
    "test": "node --test",
    "validate": "node scripts/validate.mjs",
    "validate:offline": "node scripts/validate.mjs --offline",
    "pack:cli": "npm pack --workspace @beekeep-sh/cli --dry-run"
  },
  "dependencies": {
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "esbuild": "0.25.12"
  }
}
